{
  "name": "vue-nmt",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/",
    "fetch:models": "node scripts/fetch-models.mjs",
    "models:fetch": "node scripts/fetch-models.mjs",
    "netlify-deploy": "netlify deploy --dir=dist",
    "netlify-deploy-prod": "netlify deploy --dir=dist --prod"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@huggingface/transformers": "^3.5.1",
    "@tailwindcss/vite": "^4.1.7",
    "@types/file-saver": "^2.0.7",
    "@vueuse/core": "^13.2.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "nanoid": "^5.1.5",
    "pinia": "^3.0.2",
    "tailwindcss": "^4.1.7",
    "vue": "^3.5.14",
    "vue-router": "^4.5.1",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.3.2"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.15.18",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.27.0",
    "eslint-plugin-oxlint": "^0.16.11",
    "eslint-plugin-vue": "~10.0.1",
    "jiti": "^2.4.2",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.16.11",
    "prettier": "3.5.3",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vue-tsc": "^2.2.10"
  }
}
